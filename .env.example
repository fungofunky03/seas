# Supabase browser client (Vite). Both vars must be set for the app to boot.
# Production: configure these in the Vercel project's Environment Variables UI.
# Local dev: copy this file to .env.local and fill in real values.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
